{
  "name": "strand",
  "private": true,
  "type": "module",
  "description": "Strand — a content-addressed substrate and typed language where AI agent swarms author one codebase in parallel through a type-checker green-gate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flogvit/strand.git"
  },
  "keywords": [
    "content-addressed",
    "crdt",
    "agents",
    "swarm",
    "merge",
    "typescript",
    "language"
  ],
  "scripts": {
    "strand": "tsx src/cli.ts",
    "strand-ts": "tsx src/ts/cli.ts",
    "strand-swarm": "tsx src/swarm/cli.ts",
    "lsp": "tsx src/lsp.ts",
    "demo": "bash examples/swarm.sh",
    "demo:ts": "bash examples/ts-swarm.sh",
    "emit-examples": "tsx scripts/emit-examples.ts",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  }
